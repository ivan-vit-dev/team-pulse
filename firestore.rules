rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isTeamAdmin(teamId) {
      return isSignedIn() &&
        request.auth.uid in
          get(/databases/$(database)/documents/teams/$(teamId)).data.adminUids;
    }

    // --- Implemented this phase ---

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Note: this app's Team/Player/Invite mutations all go through Server
    // Actions using firebase-admin (which bypasses these rules) — see
    // src/lib/teams/, src/lib/players/. These rules are defense-in-depth
    // for any future direct client reads/writes (e.g. real-time listeners).
    match /teams/{teamId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.adminUids
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isTeamAdmin(teamId);
      allow delete: if false;
    }

    // Public-safe player fields only — see PlayerPublic in
    // src/lib/types/player.ts. Real name/birthdate live in the private/
    // subcollection below, never here (Firestore has no field-level read
    // security, so anything on this doc is as readable as the doc itself).
    match /players/{playerId} {
      allow read: if true;
      allow create: if isTeamAdmin(request.resource.data.teamId)
        && (request.resource.data.isYouth == false
            || request.resource.data.avatarURL == null);
      allow update: if isTeamAdmin(resource.data.teamId)
        && (request.resource.data.isYouth == false
            || request.resource.data.avatarURL == null);
      allow delete: if isTeamAdmin(resource.data.teamId);

      // SRS §8: real name / birthdate — admins of the parent team only.
      match /private/{document=**} {
        allow read, write: if isTeamAdmin(
          get(/databases/$(database)/documents/players/$(playerId)).data.teamId
        );
      }
    }

    // Accept/decline is done via Server Action (acceptInvite/declineInvite)
    // so the invite-status update and adminUids update stay atomic and
    // authorized in one place, rather than trusting two separate client
    // writes to agree.
    match /teamAdminInvites/{inviteId} {
      allow read: if isSignedIn() && (
        isTeamAdmin(resource.data.teamId) ||
        resource.data.invitedEmail == request.auth.token.email
      );
      allow create: if isTeamAdmin(request.resource.data.teamId);
      allow update, delete: if isTeamAdmin(resource.data.teamId);
    }

    // --- Reserved for later phases ---
    // Rules below are permissive placeholders (any signed-in user may
    // read/write) so the collections are usable in development, but they do
    // NOT reflect final access control. Each is annotated with the phase
    // that will replace it with real rules — see APP_DESIGN.md / CLAUDE.md
    // phase roadmap.

    // TODO Phase "Seasons & Actions": writes restricted to admins of the
    // parent team.
    match /seasons/{seasonId} {
      allow read, write: if isSignedIn();
    }

    // TODO Phase "Seasons & Actions": writes restricted to admins of the
    // parent team; squad assignment restricted similarly.
    match /actions/{actionId} {
      allow read, write: if isSignedIn();
    }

    // TODO Phase "Comments/Media/Reactions": writes require the author to
    // match request.auth.uid; deletes/pins restricted to team admins;
    // moderation-removed content hidden from non-moderators.
    match /comments/{commentId} {
      allow read, write: if isSignedIn();
    }

    // TODO Phase "Comments/Media/Reactions": upload metadata written by
    // admins only; actual bytes governed by storage.rules.
    match /media/{mediaId} {
      allow read, write: if isSignedIn();
    }

    // TODO Phase "Moderation": create allowed by any signed-in user,
    // read/update/delete restricted to platform moderators only.
    match /reports/{reportId} {
      allow read, write: if isSignedIn();
    }
  }
}
