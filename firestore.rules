rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isTeamAdmin(teamId) {
      return isSignedIn() &&
        request.auth.uid in
          get(/databases/$(database)/documents/teams/$(teamId)).data.adminUids;
    }

    // --- Implemented this phase ---

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Note: this app's Team/Player/Invite mutations all go through Server
    // Actions using firebase-admin (which bypasses these rules) — see
    // src/lib/teams/, src/lib/players/. These rules are defense-in-depth
    // for any future direct client reads/writes (e.g. real-time listeners).
    match /teams/{teamId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.adminUids
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isTeamAdmin(teamId);
      allow delete: if false;
    }

    // Public-safe player fields only — see PlayerPublic in
    // src/lib/types/player.ts. Real name/birthdate live in the private/
    // subcollection below, never here (Firestore has no field-level read
    // security, so anything on this doc is as readable as the doc itself).
    match /players/{playerId} {
      allow read: if true;
      allow create: if isTeamAdmin(request.resource.data.teamId)
        && (request.resource.data.isYouth == false
            || request.resource.data.avatarURL == null);
      allow update: if isTeamAdmin(resource.data.teamId)
        && (request.resource.data.isYouth == false
            || request.resource.data.avatarURL == null);
      allow delete: if isTeamAdmin(resource.data.teamId);

      // SRS §8: real name / birthdate — admins of the parent team only.
      match /private/{document=**} {
        allow read, write: if isTeamAdmin(
          get(/databases/$(database)/documents/players/$(playerId)).data.teamId
        );
      }
    }

    // Accept/decline is done via Server Action (acceptInvite/declineInvite)
    // so the invite-status update and adminUids update stay atomic and
    // authorized in one place, rather than trusting two separate client
    // writes to agree.
    match /teamAdminInvites/{inviteId} {
      allow read: if isSignedIn() && (
        isTeamAdmin(resource.data.teamId) ||
        resource.data.invitedEmail == request.auth.token.email
      );
      allow create: if isTeamAdmin(request.resource.data.teamId);
      allow update, delete: if isTeamAdmin(resource.data.teamId);
    }

    // Note: like teams/players/invites above, Season/Action mutations all go
    // through Server Actions using firebase-admin (bypasses these rules) —
    // see src/lib/seasons/, src/lib/actions/. These rules are defense-in-depth
    // for any future direct client reads/writes (e.g. real-time listeners).
    // World-readable to match teams/players — no privacy dimension here
    // (contrast players/{id}/private).
    match /seasons/{seasonId} {
      allow read: if true;
      allow create: if isTeamAdmin(request.resource.data.teamId);
      allow update, delete: if isTeamAdmin(resource.data.teamId);
    }

    // Squad assignment (squadPlayerIds) is validated against the team's
    // actual roster at the Server Action layer (createActionAction /
    // updateActionAction in admin/actions.ts), not here — rules have no
    // cheap way to check that each array entry references a player on this
    // same team without a get() per entry, and real writes never go through
    // these rules anyway. A flat isTeamAdmin(teamId) check is the correct
    // amount of defense-in-depth.
    match /actions/{actionId} {
      allow read: if true;
      allow create: if isTeamAdmin(request.resource.data.teamId);
      allow update, delete: if isTeamAdmin(resource.data.teamId);
    }

    // Comment/Media mutations also go through Server Actions using
    // firebase-admin (bypasses these rules) — see src/lib/comments/,
    // src/lib/media/. Defense-in-depth only, same as every other collection
    // above. Hard delete by author-or-admin this phase — no moderator role
    // or soft-delete/audit trail yet; that's Phase "Moderation".
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.authorUid;
      allow update: if isTeamAdmin(resource.data.teamId);
      allow delete: if isSignedIn() &&
        (request.auth.uid == resource.data.authorUid || isTeamAdmin(resource.data.teamId));
    }

    // Uploads are team-admin only this phase (see storage.rules for the
    // actual bytes) — a deliberate youth-privacy-motivated choice, not the
    // open-fan-upload default the "engagement layer" framing might suggest.
    match /media/{mediaId} {
      allow read: if true;
      allow create: if isTeamAdmin(request.resource.data.teamId);
      allow delete: if isTeamAdmin(resource.data.teamId);
    }

    // Report mutations all go through Server Actions using firebase-admin
    // (bypasses these rules) — see src/lib/reports/, reportContentAction in
    // src/app/[locale]/teams/[teamId]/actions.ts, and
    // resolveReportAction/dismissReportAction/removeReportedContentAction in
    // src/app/[locale]/(app)/teams/[teamId]/admin/actions.ts. Defense-in-depth
    // only, same as every other collection above. Deliberately no
    // platform-wide moderator role — a team's own adminUids moderate reports
    // against that team's own content (comments/media/players/the team itself).
    match /reports/{reportId} {
      allow read: if isTeamAdmin(resource.data.teamId) ||
        (isSignedIn() && request.auth.uid == resource.data.reporterUid);
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.reporterUid
        && request.resource.data.status == "pending";
      allow update, delete: if isTeamAdmin(resource.data.teamId);
    }
  }
}
